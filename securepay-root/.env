# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=secure_user
DB_PASSWORD=super_secret_password_change_in_production
DB_NAME=securepay_db

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Service Ports
PORT_GATEWAY=3000
PORT_AUTH=3001
PORT_TRANSFER=3002
PORT_AUDIT=3003

# Service URLs
AUTH_SERVICE_URL=http://auth-service:3001
TRANSFER_SERVICE_URL=http://transfer-service:3002
AUDIT_SERVICE_URL=http://audit-logs:3003

# Security Configuration
BCRYPT_ROUNDS=10
RATE_LIMIT=100
RATE_LIMIT_WINDOW=900000

# Logging
LOG_LEVEL=info
NODE_ENV=production
